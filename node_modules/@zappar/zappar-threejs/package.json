{
  "name": "@zappar/zappar-threejs",
  "version": "4.3.0",
  "description": "ThreeJS wrappers for Zappar's computer vision library",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "homepage": "https://zap.works/universal-ar/",
  "scripts": {
    "build:standalone": "webpack --config=webpack.config.standalone.js --mode=production",
    "build:standalone-debug": "webpack --config=webpack.config.standalone.dev.js --mode=development",
    "build:module": "rm -rf lib && tsc && rm -rf lib/tests && mv lib/src/* lib && rm -rf lib/src",
    "build": "npm run build:standalone && npm run build:module",
    "build:tests": "webpack --config=webpack.config.tests.js --mode=development",
    "test": "npm run build:tests && playwright test",
    "start": "npm run build && webpack serve --mode development --config=webpack.config.tests.js",
    "typedoc": "typedoc --out docs src/index.ts --excludePrivate --excludeProtected --theme minimal",
    "watch": "tsc -w --noEmit"
  },
  "author": {
    "name": "Zappar Limited",
    "url": "https://www.zappar.com/"
  },
  "license": "MIT",
  "files": [
    "README.md",
    "lib/**/*"
  ],
  "devDependencies": {
    "three": "^0.164.0",
    "@types/three": "0.164.0"
  },
  "peerDependencies": {
    "three": ">=0.154"
  },
  "dependencies": {
    "@zappar/zappar": "4.3.0"
  },
  "release": {
    "extends": "semantic-release-commit-filter",
    "ci": true,
    "branches": [
      "main",
      {
        "name": "beta",
        "channel": "beta",
        "prerelease": "beta"
      },
      {
        "name": "alpha",
        "channel": "alpha",
        "prerelease": "alpha"
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/gitlab",
      "@semantic-release/git",
      [
        "@semantic-release/exec",
        {
          "verifyReleaseCmd": "npx -y semantic-release-npm-workspaces-monorepo cache ${nextRelease.version}"
        }
      ]
    ],
    "tagFormat": "@zappar/zappar-threejs@${version}"
  }
}
