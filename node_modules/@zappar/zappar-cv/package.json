{
  "name": "@zappar/zappar-cv",
  "version": "3.9.2",
  "description": "Zappar's core computer vision library, supporting image, face and world tracking.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build-standalone": "webpack --config=webpack.config.standalone.js --mode=production",
    "build-standalone-debug": "webpack --config=webpack.config.standalone.js --mode=development",
    "build-module": "tsc",
    "tsc-watch": "tsc --watch",
    "test-module": "npx playwright test --config playwright.config.module.ts",
    "test-standalone": "npx playwright test --config playwright.config.standalone.ts",
    "test-cdn": "npx playwright test --config playwright.config.cdn.ts",
    "test-cdn-live": "npx playwright test --config playwright.config.cdn-live.ts",
    "tests": "webpack --config=webpack.tests.config.js --mode=development && webpack serve --mode=development --config=webpack.tests.config.js",
    "tests-with-tracing": "webpack --config=webpack.testswithtracing.config.js --mode=development && webpack serve --mode=development --config=webpack.testswithtracing.config.js",
    "tests-with-tracing-prod": "webpack --config=webpack.testswithtracing.config.js --mode=production && webpack serve --mode=production --config=webpack.testswithtracing.config.js",
    "webpack-puppeteer": "webpack --config=webpack.config.puppeteer.js --mode=development && webpack serve --config=webpack.config.puppeteer.js",
    "audit": "better-npm-audit audit --production"
  },
  "author": "Zappar Limited",
  "files": [
    "README.md",
    "CHANGELOG.md",
    "lib/**/*"
  ],
  "license": "Proprietary",
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/dom-mediacapture-transform": "0.1.1",
    "@types/node": "14.14.7",
    "@types/offscreencanvas": "2019.6.4",
    "@types/pngjs": "6.0.0",
    "@types/ua-parser-js": "0.7.33",
    "@types/webxr": "0.5.22",
    "@zappar/zapworks-cli": "2.0.6",
    "better-npm-audit": "^3.7.3",
    "dat.gui": "0.7.7",
    "html-webpack-plugin": "5.5.0",
    "jsdoc": "3.6.7",
    "pngjs": "6.0.0",
    "ts-loader": "9.2.6",
    "typescript": "4.0.5",
    "webpack": "5.89.0",
    "webpack-cli": "4.9.2",
    "webpack-dev-server": "^4.7.3",
    "worker-loader": "^3.0.8",
    "@types/dom-webcodecs": "0.1.2"
  },
  "dependencies": {
    "@types/w3c-generic-sensor": "^1.0.9",
    "gl-matrix": "3.4.3",
    "ua-parser-js": "1.0.33"
  }
}
